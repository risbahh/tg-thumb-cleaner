# ── Required ──────────────────────────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here

# Generate with: python session_gen.py
SESSION_STRING=BQA...

# Channel to watch (username or -100xxx ID)
SOURCE_CHANNEL=@ClipmateZone_New

# Your index channel ID (negative integer)
DEST_CHANNEL=-100123456789

# ── Optional ──────────────────────────────────────────────────
# Your Telegram user ID — who can use /status command
ADMINS=123456789

# Seconds to wait between forwards (default: 2)
DELAY=2

# Channel to receive startup/error notifications
LOG_CHANNEL=-100987654321
